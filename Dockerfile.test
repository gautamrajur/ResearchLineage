FROM python:3.11-slim

WORKDIR /app

# Install only the packages the task modules and tests actually use
RUN pip install --no-cache-dir \
    networkx \
    pydantic-settings \
    python-dotenv \
    httpx \
    redis \
    sqlalchemy \
    psycopg2-binary \
    alembic \
    google-cloud-storage \
    mlflow \
    pytest \
    pytest-mock \
    pytest-asyncio \
    pytest-cov \
    pytest-html \
    ruff \
    mypy \
    types-redis \
    pandas

# Copy source + tests + scripts + dags
COPY src/ /app/src/
COPY tests/ /app/tests/
COPY scripts/ /app/scripts/
COPY dags/ /app/dags/
COPY pyproject.toml /app/

ENV PYTHONPATH=/app

CMD ["sh", "-c", "ruff check . && python scripts/validate_dags.py && pytest tests/unit/ -v --tb=short -m 'unit or not integration'"]
