# ══════════════════════════════════════════════════════════════════════
# API Keys — fill in before running
# ══════════════════════════════════════════════════════════════════════
SEMANTIC_SCHOLAR_API_KEY=          # optional — increases S2 rate limits
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
SEMANTIC_SCHOLAR_RATE_LIMIT=100
ARXIV_BASE_URL=http://export.arxiv.org/api/query
OPENALEX_BASE_URL=https://api.openalex.org

GEMINI_API_KEY=YOUR_GEMINI_API_KEY  # required — get from aistudio.google.com

OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
GROQ_API_KEY=YOUR_GROQ_API_KEY

# ══════════════════════════════════════════════════════════════════════
# Backend DB — Cloud SQL via proxy
# ══════════════════════════════════════════════════════════════════════
S2_API_KEY=
PG_PASSWORD=jithin
# For local dev (proxy on localhost):
DATABASE_URL=postgresql://jithin:jithin@127.0.0.1:5432/researchlineage?options=-csearch_path%3Ddeployment_schema
# For Docker (proxy on host machine — swap 127.0.0.1 → host.docker.internal):
# DATABASE_URL=postgresql://jithin:jithin@host.docker.internal:5432/researchlineage?options=-csearch_path%3Ddeployment_schema

# ══════════════════════════════════════════════════════════════════════
# Local / Airflow Postgres
# ══════════════════════════════════════════════════════════════════════
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=research_lineage
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# ══════════════════════════════════════════════════════════════════════
# Redis
# ══════════════════════════════════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL=172800

# ══════════════════════════════════════════════════════════════════════
# GCS (Google Cloud Storage)
# ══════════════════════════════════════════════════════════════════════
GCS_BUCKET_NAME=researchlineage-gcs
GCS_PROJECT_ID=researchlineage
GCS_UPLOAD_PREFIX=fine-tuning-artifacts/
GOOGLE_CLOUD_PROJECT=mlops-researchlineage

# ══════════════════════════════════════════════════════════════════════
# GCP credentials — path to your gcloud config directory
# ══════════════════════════════════════════════════════════════════════
GCLOUD_CONFIG_DIR=~/.config/gcloud   # Linux/Mac
# GCLOUD_CONFIG_DIR=C:/Users/<you>/AppData/Roaming/gcloud  # Windows

# ══════════════════════════════════════════════════════════════════════
# Cloud SQL
# Instance: researchlineage:us-central1:researchlineage-db
# ══════════════════════════════════════════════════════════════════════
CLOUD_SQL_HOST=localhost
CLOUD_SQL_PORT=5432
CLOUD_SQL_DB=researchlineage
CLOUD_SQL_USER=jithin
CLOUD_SQL_PASSWORD=jithin

# ══════════════════════════════════════════════════════════════════════
# Vertex AI
# ══════════════════════════════════════════════════════════════════════
VERTEX_API_KEY=YOUR_VERTEX_API_KEY
VERTEX_PROJECT_ID=YOUR_VERTEX_PROJECT_ID

# ══════════════════════════════════════════════════════════════════════
# Evaluation pipeline
# ══════════════════════════════════════════════════════════════════════
EVAL_FINETUNING_DATA_SOURCE=gcs
EVAL_FINETUNING_DATA_GCS_PATH=gs://researchlineage-gcs/fine-tuning-artifacts/test-eval-dag/test_subset5.jsonl
EVAL_VERTEX_PROJECT=testing-488212
EVAL_VERTEX_LOCATION=us-central1
EVAL_MODEL_ENDPOINT=gemini-2.5-pro
EVAL_OUTPUT_DIR=/tmp/eval_dag_output

# ══════════════════════════════════════════════════════════════════════
# Pipeline settings
# ══════════════════════════════════════════════════════════════════════
MAX_CITATION_DEPTH=3
MAX_PAPERS_PER_LEVEL=15
MIN_CITATION_COUNT=10
INFLUENTIAL_CITATION_WEIGHT=2.0

# ══════════════════════════════════════════════════════════════════════
# Monitoring / Logging
# ══════════════════════════════════════════════════════════════════════
LOG_LEVEL=INFO
ENABLE_METRICS=true

# ══════════════════════════════════════════════════════════════════════
# Environment
# ══════════════════════════════════════════════════════════════════════
ENVIRONMENT=development

# ══════════════════════════════════════════════════════════════════════
# Modal
# ══════════════════════════════════════════════════════════════════════
MODAL_TOKEN_ID=YOUR_MODAL_TOKEN_ID
MODAL_TOKEN_SECRET=YOUR_MODAL_TOKEN_SECRET
