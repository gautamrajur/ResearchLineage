# ── Vertex AI / GCP ──────────────────────────────────────────────────────────
GCS_PROJECT_ID=researchlineage-488918
GCS_BUCKET_NAME=researchlineage-gcs
VERTEX_REGION=us-central1

# Artifact Registry repo name (created with gcloud artifacts repositories create)
ARTIFACT_REGISTRY_REPO=training

# ── Data paths in GCS ────────────────────────────────────────────────────────
# Training data will be uploaded to: gs://<bucket>/<GCS_FT_PREFIX>/train.jsonl
GCS_FT_PREFIX=finetuning/data

# Model artifacts will be saved to: gs://<bucket>/<GCS_UPLOAD_PREFIX>/custom_training_output/<timestamp>
GCS_UPLOAD_PREFIX=finetuning/output

# ── Model Garden weights (GCS FUSE path) ─────────────────────────────────────
# Copy one of these lines (verify the bucket exists in your region first):
#
# Llama 3.1 8B (base):
# MODEL_GARDEN_GCS_URI=gs://vertex-model-garden-public-us-central1/llama3_1/llama-3.1-8b
#
# Llama 3.1 8B Instruct (recommended for instruction fine-tuning):
MODEL_GARDEN_GCS_URI=gs://vertex-model-garden-public-us-central1/llama3_1/llama-3.1-8b-instruct
#
# Llama 3.1 70B Instruct (needs A100 80GB or multiple GPUs):
# MODEL_GARDEN_GCS_URI=gs://vertex-model-garden-public-us-central1/llama3_1/llama-3.1-70b-instruct
